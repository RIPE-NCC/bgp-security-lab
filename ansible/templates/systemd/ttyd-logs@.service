[Unit]
Description=ttyd-logs instance %I

[Service]
User={{ ansible_facts.env.SUDO_USER or ansible_facts.user_id }}
Group=www-data
RuntimeDirectory=ttyd-container
UMask=0002
ExecStart=/opt/ttyd -W -i /run/ttyd-container/%i-logs.sock -t fontSize=14 -t disableLeaveAlert=true incus exec %i -t -- tail -n500 -f /var/log/messages
Type=simple
Restart=always

[Install]
WantedBy=default.target

